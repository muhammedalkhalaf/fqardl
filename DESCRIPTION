Package: fqardl
Type: Package
Title: Fourier ARDL Methods: Quantile, Nonlinear, Multi-Threshold & Unit Root Tests
Version: 1.0.0
Date: 2026-02-25
Authors@R: c(
    person("Muhammad", "Alkhalaf", 
           email = "muhammedalkhalaf@gmail.com", 
           role = c("aut", "cre", "cph"),
